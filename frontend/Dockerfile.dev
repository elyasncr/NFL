# ─────────────────────────────────────────────────────────────────
#  NFL Analytics Frontend — Dockerfile de DESENVOLVIMENTO
#  Vite com hot reload (HMR) via WebSocket
# ─────────────────────────────────────────────────────────────────
FROM node:20-alpine

WORKDIR /app

# Instala dependências em camada separada
COPY package*.json ./
RUN npm install

# Copia o restante do código (sobrescrito pelo volume no dev)
COPY . .

EXPOSE 5173

# --host: necessário para acessar de fora do container
# --port: explícito para o docker-compose mapear
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
